---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Vazcade - The coolest games created by AI" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Vazcade</title>
	</head>
	<body class="bg-gray-900 text-gray-100 min-h-screen flex flex-col font-mono">
		<header class="bg-gray-800 border-b border-gray-700 py-4 shadow-lg sticky top-0 z-10">
			<div class="container mx-auto px-4 flex justify-between items-center">
				<a href="/" class="text-2xl font-bold tracking-wider text-purple-400 hover:text-purple-300 transition-colors">
					👾 VAZCADE
				</a>
				<nav>
					<a href="/" class="text-gray-300 hover:text-white px-3 py-2 rounded-md hover:bg-gray-700 transition">
						All Games
					</a>
				</nav>
			</div>
		</header>

		<main class="flex-grow container mx-auto px-4 py-8">
			<slot />
		</main>

		<footer class="bg-gray-800 border-t border-gray-700 py-6 text-center text-sm text-gray-500">
			<p>&copy; {new Date().getFullYear()} Vazcade. Games by the Vaz Kids & AI.</p>
		</footer>
	</body>
</html>
