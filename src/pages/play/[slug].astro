---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const games = await getCollection('games');
  return games.map(game => ({
    params: { slug: game.slug },
    props: { game },
  }));
}

const { game } = Astro.props;
const gameUrl = `/games/${game.data.folder}/index.html`;
---

<Layout title={game.data.title}>
	<div class="mb-8">
		<a href="/" class="text-purple-400 hover:text-purple-300 transition-colors flex items-center gap-2 mb-4">
			← Back to Arcade
		</a>
		<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-2">
            <h1 class="text-4xl font-bold text-white">{game.data.title}</h1>
            <a href={gameUrl} target="_blank" class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700 transition-colors shadow-lg">
                Full Screen ↗
            </a>
        </div>
		<p class="text-gray-400">{game.data.description}</p>
	</div>

	<div class="bg-black rounded-xl overflow-hidden shadow-2xl border border-gray-700 aspect-video relative group">
		<iframe 
			src={gameUrl} 
			class="w-full h-full border-0 focus:outline-none" 
			title={game.data.title}
			loading="lazy"
			allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
			allowfullscreen
		></iframe>
		
		<div class="absolute inset-0 bg-black/50 flex items-center justify-center opacity-0 pointer-events-none group-hover:opacity-0 transition-opacity duration-300">
			<!-- Overlay or loading state could go here -->
		</div>
	</div>

	<div class="mt-8 grid md:grid-cols-2 gap-8">
		<div class="bg-gray-800 p-6 rounded-lg border border-gray-700">
			<h3 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
				🎮 Controls
			</h3>
			<p class="text-gray-300 font-mono text-sm leading-relaxed">
				{game.data.controls || "No specific controls listed. Try clicking or using arrow keys!"}
			</p>
		</div>

		<div class="bg-gray-800 p-6 rounded-lg border border-gray-700">
			<h3 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
				📝 About
			</h3>
			<div class="text-gray-300 text-sm prose prose-invert">
				<p>Created by: <span class="text-purple-400 font-semibold">{game.data.author}</span></p>
				<p>Published: {game.data.publishDate.toLocaleDateString()}</p>
			</div>
		</div>
	</div>
</Layout>
