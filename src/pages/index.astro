---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const games = await getCollection('games');
---

<Layout title="Home">
	<div class="text-center mb-12">
		<h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">
			Welcome to <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-600">VAZCADE</span>
		</h1>
		<p class="text-xl text-gray-400 max-w-2xl mx-auto">
			The spot where AI-powered games come to life. Click, play, and enjoy!
		</p>
	</div>

	<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
		{games.map((game) => (
			<a href={`/play/${game.slug}`} class="group bg-gray-800 rounded-xl overflow-hidden border border-gray-700 hover:border-purple-500 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-2xl">
				<div class="aspect-video bg-gray-900 flex items-center justify-center border-b border-gray-700 relative overflow-hidden">
					<span class="text-6xl group-hover:scale-110 transition-transform duration-300">🕹️</span>
					<div class="absolute inset-0 bg-purple-900/10 group-hover:bg-purple-900/20 transition-colors"></div>
				</div>
				<div class="p-6">
					<h2 class="text-2xl font-bold text-white mb-2 group-hover:text-purple-400 transition-colors">{game.data.title}</h2>
					<p class="text-gray-400 text-sm mb-4 line-clamp-2">{game.data.description}</p>
					
					<div class="flex items-center justify-between text-xs text-gray-500 font-mono border-t border-gray-700 pt-4">
						<span class="flex items-center gap-1">
							👤 {game.data.author}
						</span>
						<span>
							📅 {game.data.publishDate.toLocaleDateString()}
						</span>
					</div>
				</div>
			</a>
		))}
	</div>

	{games.length === 0 && (
		<div class="text-center py-20 bg-gray-800 rounded-xl border border-dashed border-gray-600">
			<p class="text-xl text-gray-400">No games yet! Add some to public/games/</p>
		</div>
	)}
</Layout>
